# Environment Configuration for Playwright Tests

# Base URLs for different environments
# Uncomment the one you want to use

# Production
# BASE_URL=https://billing.empcloud.com

# Local Development
# BASE_URL=http://localhost:3000

# Staging
# BASE_URL=https://staging-billing.empcloud.com

# Active example environment
BASE_URL=https://test-billing.empcloud.com

# Test Configuration
TIMEOUT=60000
HEADLESS=true

# Credentials
ADMIN_EMAIL=your-email@example.com
ADMIN_PASSWORD=your-password
